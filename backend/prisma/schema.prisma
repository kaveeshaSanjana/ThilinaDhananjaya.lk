generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  ADMIN
  STUDENT
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  PENDING
  OLD
}

enum RecordingStatus {
  ANYONE
  STUDENTS_ONLY
  PAID_ONLY
  PRIVATE
  INACTIVE
}

enum MonthStatus {
  ANYONE
  STUDENTS_ONLY
  PAID_ONLY
  PRIVATE
  INACTIVE
}

enum ClassStatus {
  ANYONE
  STUDENTS_ONLY
  PAID_ONLY
  PRIVATE
  INACTIVE
}

enum LectureStatus {
  ANYONE
  STUDENTS_ONLY
  PAID_ONLY
  PRIVATE
  INACTIVE
}

enum LectureMode {
  ONLINE
  OFFLINE
}

enum PaymentType {
  MONTHLY
  ADMISSION
  OTHER
}

enum PaymentSlipStatus {
  PENDING
  VERIFIED
  REJECTED
  LATE
}

enum PaymentMethod {
  ONLINE
  PHYSICAL
}

enum PaymentPortion {
  FULL
  HALF
}

enum EnrollmentPaymentType {
  FULL
  HALF
  FREE
}

enum AttendanceStatus {
  COMPLETED
  INCOMPLETE
  MANUAL
}

enum WatchSessionStatus {
  WATCHING
  PAUSED
  ENDED
}

enum VideoType {
  DRIVE
  YOUTUBE
  ZOOM
  OTHER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MediaType {
  PDF
  IMAGE
  LINK
  DOCUMENT
  OTHER
}

// ─── Institute (Multi-Tenant) ──────────────────────────────

model Institute {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  logoUrl     String?  @db.Text
  address     String?
  phone       String?
  description String?  @db.Text
  themeColor  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users   User[]   @relation("UserOrg")
  classes Class[]  @relation("ClassOrg")
  admins  AdminInstitute[]
}

model AdminInstitute {
  id          String    @id @default(uuid())
  adminId     String
  instituteId String
  isOwner     Boolean   @default(false)
  createdAt   DateTime  @default(now())

  admin     User      @relation("AdminAccess", fields: [adminId], references: [id], onDelete: Cascade)
  institute Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@unique([adminId, instituteId])
  @@index([adminId])
  @@index([instituteId])
}

// ─── Auth / User ─────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String?  @unique // Optional - can register without email if using instituteUserId/barcodeId
  password  String
  role      Role     @default(STUDENT)
  orgId     String?  // FK to Institute (set for students; also set for admins as default institute)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org                Institute?          @relation("UserOrg", fields: [orgId], references: [id])
  adminAccess        AdminInstitute[]    @relation("AdminAccess")
  profile            Profile?
  enrollments        Enrollment[]
  payments           PaymentSlip[]
  attendances        Attendance[]
  watchSessions      WatchSession[]
  refreshTokens      RefreshToken[]
  classAttendances   ClassAttendance[]
  lectureAttendances LectureAttendance[]

  @@index([orgId])
}

// ─── Refresh Token ───────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ─── Student Profile ─────────────────────────────────────

model Profile {
  id            String        @id @default(uuid())
  userId        String        @unique
  instituteId   String        @unique  // e.g. TD-2026-0001
  barcodeId     String?       @unique  // Physical barcode on student ID card
  fullName      String
  avatarUrl     String?       @db.Text // Profile picture URL (S3)
  address       String?
  // ─── Contact Numbers ───
  phone         String?       // Student mobile/telephone
  telephone     String?       // Student secondary telephone
  whatsappPhone String?       // Student WhatsApp number
  guardianPhone String?       // Guardian/Parent mobile/telephone
  guardianTelephone String?   // Guardian/Parent secondary telephone
  emergencyContactPhone String? // Emergency contact number
  emergencyContactName  String? // Emergency contact name
  // ───────────────────────
  school        String?
  dateOfBirth   DateTime?
  guardianName  String?
  relationship  String?
  occupation    String?
  gender        Gender?
  status        StudentStatus @default(PENDING)
  enrolledDate  DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone])
  @@index([telephone])
  @@index([whatsappPhone])
  @@index([guardianPhone])
  @@index([guardianTelephone])
  @@index([emergencyContactPhone])
  @@index([status])
  @@index([fullName])
}

// ─── Class / Month / Recording Hierarchy ─────────────────

model Class {
  id             String      @id @default(uuid())
  name           String
  subject        String?
  description    String?     @db.Text
  monthlyFee     Float?
  thumbnail      String?     @db.Text // URL to thumbnail image
  vision         String?     @db.Text
  mission        String?     @db.Text
  introVideoUrl  String?     @db.Text // Intro/promo video URL
  status         ClassStatus @default(ANYONE)
  orgId          String?     // FK to Institute
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  org              Institute?        @relation("ClassOrg", fields: [orgId], references: [id])
  months           Month[]
  enrollments      Enrollment[]
  classAttendances ClassAttendance[]
  classAttendanceSessions ClassAttendanceSession[]
  classAttendanceWeeks    ClassAttendanceWeek[]

  @@index([orgId])
}

model Month {
  id        String      @id @default(uuid())
  classId   String
  name      String      // e.g. "January 2026"
  year      Int
  month     Int         // 1-12
  status    MonthStatus @default(ANYONE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  class      Class       @relation(fields: [classId], references: [id], onDelete: Cascade)
  recordings Recording[]
  payments   PaymentSlip[]
  lectures   Lecture[]
  media      MonthMedia[]

  @@unique([classId, year, month])
  @@index([classId])
}

model Lecture {
  id              String        @id @default(uuid())
  monthId         String
  title           String
  description     String?       @db.Text
  mode            LectureMode   @default(ONLINE)
  platform        String?       // e.g. Zoom, Google Meet, Microsoft Teams
  startTime       DateTime
  endTime         DateTime
  sessionLink     String?       @db.Text
  meetingId       String?
  meetingPassword String?
  maxParticipants Int?
  welcomeMessage  String?       @db.Text  // Rich text HTML with variable placeholders e.g. {{studentName}}
  liveToken       String?       @unique   // Shareable join token e.g. /lecture-live/{token}
  cardImageUrl    String?       @db.Text  // Optional image shown on the join-page info panel
  bgMediaUrl      String?       @db.Text  // Optional background image or looping video URL for join page
  status          LectureStatus @default(STUDENTS_ONLY)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  month               Month                @relation(fields: [monthId], references: [id], onDelete: Cascade)
  lectureAttendances   LectureAttendance[]
  guestJoins           GuestLectureJoin[]

  @@index([monthId])
  @@index([status])
  @@index([startTime])
}

model Recording {
  id              String           @id @default(uuid())
  monthId         String
  title           String
  description     String?          @db.Text
  videoUrl        String?          @db.Text // Signed URL or external link (optional for live lectures)
  videoType       VideoType?       // DRIVE, YOUTUBE, ZOOM, OTHER
  thumbnail       String?          @db.Text // URL to thumbnail image
  duration        Int?             // Duration in seconds
  topic           String?
  icon            String?          // Icon name or URL
  materials       String?          @db.Text // JSON array of material links/names
  welcomeMessage  String?          @db.Text // Rich text HTML with variable placeholders e.g. {{studentName}}
  isLive          Boolean          @default(false)
  liveUrl         String?          @db.Text // The actual live meeting URL (Zoom/Meet/etc)
  liveToken       String?          @unique  // Unique token for shareable link e.g. /live/{token}
  liveStartedAt   DateTime?        // When live session started
  liveEndedAt     DateTime?        // When live session ended
  status          RecordingStatus  @default(PAID_ONLY)
  order           Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  month         Month          @relation(fields: [monthId], references: [id], onDelete: Cascade)
  attendances   Attendance[]
  watchSessions WatchSession[]

  @@index([monthId])
  @@index([monthId, order])
  @@index([status])
  @@index([isLive])
}

// ─── Month Media (Study Materials) ─────────────────────────

model MonthMedia {
  id          String          @id @default(uuid())
  monthId     String
  title       String
  description String?         @db.Text
  fileUrl     String          @db.Text
  mediaType   MediaType       @default(OTHER)
  thumbnail   String?         @db.Text
  size        Int?            // file size in bytes
  order       Int             @default(0)
  status      RecordingStatus @default(STUDENTS_ONLY)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  month Month @relation(fields: [monthId], references: [id], onDelete: Cascade)

  @@index([monthId])
  @@index([monthId, order])
  @@index([status])
}

// ─── Enrollment (Student <-> Class) ──────────────────────

model Enrollment {
  id             String                @id @default(uuid())
  userId         String
  classId        String
  paymentType    EnrollmentPaymentType @default(FULL)
  customMonthlyFee Float?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([userId, classId])
  @@index([userId])
  @@index([classId])
  @@index([classId, paymentType])
  @@index([classId, customMonthlyFee])
}

// ─── Payment Slip ────────────────────────────────────────

model PaymentSlip {
  id            String            @id @default(uuid())
  userId        String
  monthId       String
  type          PaymentType
  reason        String?           // Required if type = OTHER
  slipUrl       String            @db.Text // URL from S3/GCS/Drive signed upload
  amount        Float?            // Amount paid (auto-filled from class.monthlyFee)
  paidDate      DateTime?         // Date the payment was made (set by admin on verify)
  transactionId String?           @unique  // Transaction/reference ID entered by admin on verify
  paymentMethod PaymentMethod?             // How payment was made: ONLINE or PHYSICAL
  paymentPortion PaymentPortion?           // Amount portion: FULL or HALF
  status        PaymentSlipStatus @default(PENDING)
  adminNote     String?
  rejectReason  String?           @db.Text // Reason for rejection (required when rejecting)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  month Month @relation(fields: [monthId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([monthId])
  @@index([status])
  @@index([userId, monthId])
  @@index([createdAt])
}

// ─── Attendance / Watch Tracking ─────────────────────────

model Attendance {
  id          String           @id @default(uuid())
  userId      String
  recordingId String?          // null for manual non-recording attendance
  eventName   String?          // For manual attendance
  status      AttendanceStatus
  watchedSec  Int?             // Total seconds watched
  liveJoinedAt DateTime?       // When user joined live lecture
  details     Json?            // JSON log of all status changes / events
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now()) @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  recording Recording? @relation(fields: [recordingId], references: [id], onDelete: SetNull)

  @@unique([userId, recordingId])
  @@index([userId])
  @@index([recordingId])
  @@index([createdAt])
}

// ─── Watch Session Tracking ──────────────────────────────

model WatchSession {
  id              String             @id @default(uuid())
  userId          String
  recordingId     String
  startedAt       DateTime           @default(now())
  endedAt         DateTime?
  videoStartPos   Float              @default(0)   // seconds into video when session started
  videoEndPos     Float              @default(0)   // last known video position
  totalWatchedSec Int                @default(0)   // actual seconds watched in this session
  status          WatchSessionStatus @default(WATCHING)
  events          Json?                             // JSON array of {type, videoTime, wallTime} events

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  recording Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)

  @@index([userId, recordingId])
  @@index([userId, startedAt])
}

// ─── Class Attendance (Physical / Date-based) ────────────

model ClassAttendance {
  id        String              @id @default(uuid())
  userId    String
  classId   String
  date      DateTime            @db.Date    // The date of the class
  sessionTime String            @default("00:00") @db.VarChar(5) // HH:mm
  sessionCode String?           @db.VarChar(120)  // Optional custom slot code, e.g. cls002sub1
  sessionAt DateTime?           // Optional exact date-time of the attendance session
  status    ClassAttendanceStatus @default(PRESENT)
  method    String?             // e.g. "barcode", "manual", "institute_id"
  note      String?
  markedBy  String?             // Admin user ID who marked
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([userId, classId, date, sessionTime])
  @@index([classId, date, sessionTime])
  @@index([userId, classId])
}

model ClassAttendanceSession {
  id          String   @id @default(uuid())
  classId     String
  weekId      String?
  date        DateTime @db.Date
  sessionTime String   @default("00:00") @db.VarChar(5)
  sessionCode String?  @db.VarChar(120)
  sessionAt   DateTime?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  class Class                @relation(fields: [classId], references: [id], onDelete: Cascade)
  week  ClassAttendanceWeek? @relation(fields: [weekId], references: [id], onDelete: SetNull)

  @@unique([classId, date, sessionTime])
  @@index([classId, weekId, date, sessionTime])
  @@index([weekId])
}

model ClassAttendanceWeek {
  id        String   @id @default(uuid())
  classId   String
  name      String   @db.VarChar(120)
  orderNo   Int      @default(0)
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  class    Class                   @relation(fields: [classId], references: [id], onDelete: Cascade)
  sessions ClassAttendanceSession[]

  @@unique([classId, name])
  @@index([classId, orderNo, createdAt])
}

enum ClassAttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

// ─── Lecture Attendance (Registered users joining via live link) ─

model LectureAttendance {
  id        String   @id @default(uuid())
  lectureId String
  userId    String
  joinedAt  DateTime @default(now())

  lecture Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lectureId, userId])
  @@index([lectureId])
  @@index([userId])
}

// ─── Guest Lecture Join (Public visitors joining ANYONE lectures) ─

model GuestLectureJoin {
  id        String   @id @default(uuid())
  lectureId String
  fullName  String
  phone     String
  email     String?
  note      String?
  joinedAt  DateTime @default(now())

  lecture Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)

  @@index([lectureId])
}
