# Environment variables for production deployment
# Copy this file to .env and fill in your values. NEVER commit .env to git.

# ── Database ──────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_DATABASE=lms_db
MYSQL_USER=lms_user
MYSQL_PASSWORD=change_this_db_password

# ── Backend ───────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_min_32chars
FRONTEND_URL=http://yourdomain.com

# ── S3 / Storage ─────────────────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=your_bucket_name
# Leave blank to use real AWS S3, or set to MinIO endpoint e.g. http://minio:9000
AWS_S3_ENDPOINT=
